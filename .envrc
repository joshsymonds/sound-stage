# Load devenv environment automatically
# See: https://devenv.sh/automatic-shell-activation/

if ! has devenv; then
  echo "devenv not found. Install it: https://devenv.sh/getting-started/"
  exit 1
fi

# Use devenv
eval "$(devenv print-dev-env)"

# Load local secrets (USDB credentials, etc.)
if [ -f .envrc.local ]; then
  source .envrc.local
fi
dotenv_if_exists .env.local
