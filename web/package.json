    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "screenshot": "tsx scripts/screenshot.ts",
    "screenshot:all": "tsx scripts/screenshot.ts --all"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@storybook/addon-svelte-csf": "^5.0.11",
    "@storybook/svelte": "^10.2.13",
    "@storybook/sveltekit": "^10.2.13",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.21.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.7",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.2",
    "@vitest/eslint-plugin": "^1.3.2",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-sonarjs": "^3.0.2",
    "eslint-plugin-svelte": "^3.9.1",
    "eslint-plugin-unicorn": "^59.0.1",
    "globals": "^16.0.0",
    "jiti": "^2.6.1",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.5.0",
    "storybook": "^10.2.13",
    "svelte": "^5.33.0",
    "svelte-check": "^4.2.1",
    "svelte-eslint-parser": "^1.1.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.32.1",
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.1"
  }
